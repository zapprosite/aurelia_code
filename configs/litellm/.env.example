# Environment variables para LiteLLM
# Copie para .env e preencha os valores

# Chave mestra do LiteLLM (requerida para admin endpoints)
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# Chave da OpenRouter (para Tier 1)
OPENROUTER_API_KEY=sk-or-change-me

# Não requer API key para Ollama (local)
OLLAMA_API_KEY=sk-ollama
