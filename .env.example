# ==============================================================================
# AURÉLIA — SOBERANA 2026 (TEMPLATE DE SECRETS & VISIBILIDADE IA)
# ==============================================================================
# ESTE ARQUIVO É O ESPELHO ESTRUTURAL DO .env REAL.
# QUALQUER AGENTE IA PODE LER ESTE ARQUIVO PARA ENTENDER A INFRAESTRUTURA.
# OS VALORES REAIS RESIDEM APENAS NO .env (PROTEGIDO POR .gitignore).
# ==============================================================================

# --- CLOUDFLARE (DNS & INFRA) ---
# Token principal da Cloudflare Dashboard (ex: Edit Zone DNS)
CLOUDFLARE_API_TOKEN={CHAVE-PARA-ENV}
# ID da conta (extraído via cloudflared)
CLOUDFLARE_ACCOUNT_ID={CHAVE-PARA-ENV}
# ID da Zona zappro.site
CLOUDFLARE_ZONE_ID={CHAVE-PARA-ENV}
# Nome do domínio principal
CLOUDFLARE_ZONE_NAME=zappro.site
# Email administrativo da conta
CLOUDFLARE_ACCOUNT_EMAIL={CHAVE-PARA-ENV}
# Token para integração MCP (Model Context Protocol)
CLOUDFLARE_MCP_TOKEN={CHAVE-PARA-ENV}

# --- CLOUDFLARE TUNNEL (SECURE ACCESS) ---
# Nome do túnel local configurado no homelab
CF_TUNNEL_NAME=will-zappro-homelab
# UUID do túnel persistido em ~/.cloudflared/
CF_TUNNEL_ID={CHAVE-PARA-ENV}
# Segredo do túnel para autenticação do conector
CF_TUNNEL_SECRET={CHAVE-PARA-ENV}
# Hostname de entrada padrão
CF_TUNNEL_CNAME=n8n.zappro.site

# --- TAILSCALE (MESH VPN) ---
# IP da rede privada Tailscale para acesso remoto
TAILSCALE_IP={CHAVE-PARA-ENV}
# Nome do nó na rede Tailscale
TAILSCALE_HOSTNAME=will-zappro

# --- TELEGRAM BOTS (IDENTIDADES) ---
# 1. Bot Mestre (Aurélia)
TELEGRAM_BOT_TOKEN={CHAVE-PARA-ENV}
# 2. Assistente de Vendas
TELEGRAM_BOT_TOKEN_AC_VENDAS={CHAVE-PARA-ENV}
# 3. Organizadora de Rotinas
TELEGRAM_BOT_TOKEN_ORGANIZADORA={CHAVE-PARA-ENV}
# 4. Gestor de Agenda
TELEGRAM_BOT_TOKEN_AGENDA={CHAVE-PARA-ENV}
# 5. Controlador de Banco de Dados
TELEGRAM_BOT_TOKEN_CONTROLE_DB={CHAVE-PARA-ENV}
# 6. Monitor de Caixa/Financeiro
TELEGRAM_BOT_TOKEN_CAIXA={CHAVE-PARA-ENV}
# 7. Bot de Notificações do Sistema
TELEGRAM_NOTIFICATION_BOT_ID={CHAVE-PARA-ENV}

# --- LLM APIs (TIER 0 & CLOUD) ---
# Chave OpenRouter para modelos de alta performance (Tier 1+)
OPENROUTER_API_KEY={CHAVE-PARA-ENV}
# Chave Groq para Llama-3 inferência ultra-rápida (Tier 0 local/cloud bridge)
GROQ_API_KEY={CHAVE-PARA-ENV}
# Chave Gemini (Google Cloud)
GOOGLE_API_KEY={CHAVE-PARA-ENV}
# Token HuggingFace para download de pesos e modelos
HF_TOKEN={CHAVE-PARA-ENV}
# Chaves fallback (Opcionais)
OPENAI_API_KEY={CHAVE-PARA-ENV}
ANTHROPIC_API_KEY={CHAVE-PARA-ENV}

# --- LITELLM PROXY (ORQUESTRADOR) ---
# Senha mestra administrativa do Proxy
LITELLM_MASTER_KEY={CHAVE-PARA-ENV}
# Chave virtual para consumo de agentes
LITELLM_VIRTUAL_KEY={CHAVE-PARA-ENV}
# Localização do banco do LiteLLM (Porta 5440)
LITELLM_POSTGRES_HOST=127.0.0.1
LITELLM_POSTGRES_PORT=5440
LITELLM_POSTGRES_USER=litellm
LITELLM_POSTGRES_DB=litellm
LITELLM_POSTGRES_PASSWORD={CHAVE-PARA-ENV}
# Endpoints públicos e locais
LITELLM_URL=https://llm.zappro.site/v1
LITELLM_LOCAL_URL=http://localhost:4000/v1
LITELLM_UI_URL=http://localhost:4000/ui

# --- QDRANT (BANCO VETORIAL) ---
# API Key extraída de /srv/apps/platform/docker-compose.yml
QDRANT_API_KEY={CHAVE-PARA-ENV}
# Endpoints local e público
QDRANT_URL=http://127.0.0.1:6333
QDRANT_URL_PUBLIC=https://qdrant.zappro.site

# --- SUPABASE (CORE DB & AUTH) ---
# Senha mestra do PostgreSQL gerida pelo Docker
SUPABASE_POSTGRES_PASSWORD={CHAVE-PARA-ENV}
# Segredo JWT para assinar tokens
SUPABASE_JWT_SECRET={CHAVE-PARA-ENV}
# Chaves públicas/serviço enviadas ao frontend
SUPABASE_ANON_KEY={CHAVE-PARA-ENV}
SUPABASE_SERVICE_ROLE_KEY={CHAVE-PARA-ENV}
# Senha de administração do dashboard
SUPABASE_DASHBOARD_PASSWORD={CHAVE-PARA-ENV}
SUPABASE_STUDIO_USER=supabase
# URLs de acesso externas
SUPABASE_URL=https://supabase.zappro.site
SUPABASE_STUDIO_URL=https://studio.zappro.site
# Portas locais
SUPABASE_DB_PORT=5433
SUPABASE_DB_DIRECT_PORT=5435

# --- N8N (WORKFLOW AUTOMATION) ---
# Senha do banco de dados n8n (extraída de docker-compose)
N8N_DB_PASSWORD={CHAVE-PARA-ENV}
# URL pública via tunnel
N8N_URL=https://n8n.zappro.site

# --- CAPROVER (PaaS) ---
# Senha administrativa do CapRover
CAPROVER_PASSWORD={CHAVE-PARA-ENV}
# URL de gerenciamento
CAPROVER_URL=https://cap.zappro.site

# --- GRAFANA (OBSERVABILIDADE) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD={CHAVE-PARA-ENV}
GRAFANA_URL=https://monitor.zappro.site
GRAFANA_LOCAL_URL=http://localhost:3100
# IDs de dashboards específicos
GRAFANA_DASHBOARD_GPU={CHAVE-PARA-ENV}
GRAFANA_DASHBOARD_NODE={CHAVE-PARA-ENV}
GRAFANA_DASHBOARD_DOCKER={CHAVE-PARA-ENV}

# --- GITHUB (REPO & CI/CD) ---
# Personal Access Token para gestão de issues e PRs
GITHUB_TOKEN={CHAVE-PARA-ENV}

# --- POSTGRES (SISTEMA) ---
# Senha global do postgres host (usada em scripts de backup)
POSTGRES_PASSWORD={CHAVE-PARA-ENV}

# --- AURELIA RUNTIME (CORE) ---
# URL do motor Ollama (Local LLM)
OLLAMA_URL=http://127.0.0.1:11434
# Diretório base de memória e logs
AURELIA_HOME=/home/will/.aurelia
# Endpoints de controle
AURELIA_HEALTH_URL=http://127.0.0.1:8484
AURELIA_DASHBOARD_URL=http://127.0.0.1:3334
AURELIA_MODE=sovereign

# --- EXTRA / CUSTOM SECRETS (Sovereign 2026 Extension) ---
TELEGRAM_TOKEN_CAIXA={CHAVE-PARA-ENV}
TELEGRAM_TOKEN_VENDAS={CHAVE-PARA-ENV}
TELEGRAM_TOKEN_OBRAS={CHAVE-PARA-ENV}
TELEGRAM_TOKEN_AGENDA={CHAVE-PARA-ENV}
TELEGRAM_TOKEN_INFRA={CHAVE-PARA-ENV}
TELEGRAM_TOKEN_DB={CHAVE-PARA-ENV}
N8N_API_KEY={CHAVE-PARA-ENV}
