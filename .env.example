# ==============================================================================
# AURÉLIA — SOBERANA 2026 (TEMPLATE DE SECRETS)
# ==============================================================================
# Este ficheiro espelha a estrutura do .env real.
# Qualquer agente pode ler para entender a infraestrutura.
# OS VALORES REAIS residem apenas no .env (protegido por .gitignore).
# ==============================================================================

# ==============================================================================
# SECÇÃO 1 — OBRIGATÓRIOS (qualquer modo)
# ==============================================================================

# TELEGRAM — IDENTIDADE PRINCIPAL
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATION_BOT_ID=

# STT — SPEECH TO TEXT (Groq Whisper)
GROQ_API_KEY=
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3-turbo
STT_BASE_URL=https://api.groq.com/openai/v1
STT_LANGUAGE=pt

# ==============================================================================
# SECÇÃO 2 — SOBERANO (GPU local)
# ==============================================================================

# LLM LOCAL — OLLAMA (RTX 4090)
OLLAMA_URL=http://127.0.0.1:4000/v1
# Modelo: gemma3:27b-it-qat (QAT - melhor qualidade)
# gemma3:27b-it-qat (18GB VRAM)
OLLAMA_MODEL=gemma3:27b-it-qat

# ==============================================================================
# SECÇÃO 3 — LITE (Cloud-first)
# ==============================================================================

# Cascade cloud — preencha apenas se usar modo lite
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ==============================================================================
# SECÇÃO 4 — VOZ (ambos modos) — Kokoro/Kodoro TTS
# ==============================================================================

# Endpoint TTS (Voxtral TTS — default localhost:8012)
TTS_BASE_URL=http://127.0.0.1:8012
# Modelo: edge-tts native
TTS_MODEL=edge-tts
TTS_PROVIDER=edge
# Voz PT-BR clonada (ver assets/voice/aurelia.mp3)
VOICE_ID=aurelia-jarvis
TTS_VOICE=pt-BR-ThalitaMultilingualNeural
# Velocidade: 0.5 a 2.0 (default 1.0)
# TTS_SPEED=1.0

# ==============================================================================
# SECÇÃO 5 — OPCIONAIS (defaults funcionam)
# ==============================================================================

# AURELIA_MODE=sovereign  (ou "lite")
# LOG_LEVEL=info          (debug, info, warn, error)
# AURELIA_HOME=~/.aurelia

# ==============================================================================
# SECÇÃO 6 — MULTI-BOTS (identidades Telegram adicionais)
# ==============================================================================

# TELEGRAM_BOT_TOKEN_AC_VENDAS=
# TELEGRAM_BOT_TOKEN_ORGANIZADORA=
# TELEGRAM_BOT_TOKEN_AGENDA=
# TELEGRAM_BOT_TOKEN_CONTROLE_DB=
# TELEGRAM_BOT_TOKEN_CAIXA=

# ==============================================================================
# SECÇÃO 7 — INFRAESTRUTURA
# ==============================================================================

# CLOUDFLARE
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CF_TUNNEL_NAME=
CF_TUNNEL_ID=
CF_TUNNEL_SECRET=

# TAILSCALE
TAILSCALE_IP=
TAILSCALE_HOSTNAME=

# LITELLM PROXY
LITELLM_MASTER_KEY=
LITELLM_VIRTUAL_KEY=

# SEARXNG (web search local)
SEARXNG_URL=http://localhost:8888

# GRAFANA — URL pública para o link no resumo do home lab
GRAFANA_URL=https://monitor.zappro.site

# QDRANT (vector DB)
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# N8N (workflow automation)
N8N_URL=
N8N_DB_PASSWORD=

# CAPROVER
CAPROVER_PASSWORD=
CAPROVER_URL=

# ==============================================================================
# SECÇÃO 8 — AURELIA RUNTIME
# ==============================================================================

# PORTEIRO SENTINEL (prompt injection guard)
# Valores: STRICT, LOG_ONLY, OFF
PORTEIRO_MODE=
# IDs Telegram autorizados (bypass do guard)
ALLOWED_USER_IDS=

# MEMÓRIA SEMÂNTICA
OBSIDIAN_VAULT_PATH=

# GITHUB
GITHUB_TOKEN=

# HUGGINGFACE (download de modelos)
HF_TOKEN=

# TAVILY (web search)
TAVILY_API_KEY=

# ==============================================================================
# SECÇÃO 9 — AURELIA_CODE (Agent Swarm)
# ==============================================================================

# A2A Protocol (Agent-to-Agent)
A2A_PORT=8080
A2A_AGENT_ID=aurelia_code

# Context7 (docs atualizadas)
CONTEXT7_ENABLED=true

# n8n Webhook para automação
N8N_WEBHOOK_URL=http://localhost:5678/webhook/aurelia

# ==============================================================================
# SECÇÃO 9 — RUNTIME POLISH (SOTA 2026)
# ==============================================================================

# GOMEMLIMIT=      (limite memória Go em containers)
# GOGC=100         (GC: maior = menos CPU, mais RAM)
# GO_RUNTIME_POLISH_ENABLED=

# ==============================================================================
# SECÇÃO 10 — FEATURE FLAGS (S-57)
# ==============================================================================

FEAT_VOICE=false
FEAT_DREAM=false
FEAT_KAIROS=false
FEAT_COMPUTER_USE=false
