# ==============================================================================
# AURГ‰LIA вЂ” SOBERANA 2026 (TEMPLATE DE SECRETS)
# ==============================================================================
# Este ficheiro espelha a estrutura do .env real.
# Qualquer agente pode ler para entender a infraestrutura.
# OS VALORES REAIS residem apenas no .env (protegido por .gitignore).
# ==============================================================================

# ==============================================================================
# SECГ‡ГѓO 1 вЂ” OBRIGATГ“RIOS (qualquer modo)
# ==============================================================================

# TELEGRAM вЂ” IDENTIDADE PRINCIPAL
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATION_BOT_ID=

# STT вЂ” SPEECH TO TEXT (Groq Whisper)
GROQ_API_KEY=

# ==============================================================================
# SECГ‡ГѓO 2 вЂ” SOBERANO (GPU local)
# ==============================================================================

# LLM LOCAL вЂ” OLLAMA (RTX 4090)
OLLAMA_URL=http://127.0.0.1:4000/v1
# Modelo: qwen3.5 (8B) ou qwen2.5-72b (requer 48GB VRAM)
# OLLAMA_MODEL=qwen3.5

# ==============================================================================
# SECГ‡ГѓO 3 вЂ” LITE (Cloud-first)
# ==============================================================================

# Cascade cloud вЂ” preencha apenas se usar modo lite
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ==============================================================================
# SECГ‡ГѓO 4 вЂ” VOZ (ambos modos) вЂ” Kokoro/Kodoro TTS
# ==============================================================================

# Endpoint TTS (Kokoro/Kodoro вЂ” default localhost:8012)
TTS_BASE_URL=http://127.0.0.1:8012
# Modelo: kokoro (default)
TTS_MODEL=kokoro
# Voz PT-BR clonada (ver assets/voice/aurelia.mp3)
VOICE_ID=aurelia-jarvis
# Velocidade: 0.5 a 2.0 (default 1.0)
# TTS_SPEED=1.0

# ==============================================================================
# SECГ‡ГѓO 5 вЂ” OPCIONAIS (defaults funcionam)
# ==============================================================================

# AURELIA_MODE=sovereign  (ou "lite")
# LOG_LEVEL=info          (debug, info, warn, error)
# AURELIA_HOME=~/.aurelia

# ==============================================================================
# SECГ‡ГѓO 6 вЂ” MULTI-BOTS (identidades Telegram adicionais)
# ==============================================================================

# TELEGRAM_BOT_TOKEN_AC_VENDAS=
# TELEGRAM_BOT_TOKEN_ORGANIZADORA=
# TELEGRAM_BOT_TOKEN_AGENDA=
# TELEGRAM_BOT_TOKEN_CONTROLE_DB=
# TELEGRAM_BOT_TOKEN_CAIXA=

# ==============================================================================
# SECГ‡ГѓO 7 вЂ” INFRAESTRUTURA
# ==============================================================================

# CLOUDFLARE
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CF_TUNNEL_NAME=
CF_TUNNEL_ID=
CF_TUNNEL_SECRET=

# TAILSCALE
TAILSCALE_IP=
TAILSCALE_HOSTNAME=

# LITELLM PROXY
LITELLM_MASTER_KEY=
LITELLM_VIRTUAL_KEY=

# QDRANT (vector DB)
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# SUPABASE
SUPABASE_URL=
SUPABASE_POSTGRES_PASSWORD=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# N8N (workflow automation)
N8N_URL=
N8N_DB_PASSWORD=

# CAPROVER
CAPROVER_PASSWORD=
CAPROVER_URL=

# ==============================================================================
# SECГ‡ГѓO 8 вЂ” AURELIA RUNTIME
# ==============================================================================

# PORTEIRO SENTINEL (prompt injection guard)
# Valores: STRICT, LOG_ONLY, OFF
PORTEIRO_MODE=
# IDs Telegram autorizados (bypass do guard)
ALLOWED_USER_IDS=

# MEMГ“RIA SEMГ‚NTICA
OBSIDIAN_VAULT_PATH=

# GITHUB
GITHUB_TOKEN=

# HUGGINGFACE (download de modelos)
HF_TOKEN=

# TAVILY (web search)
TAVILY_API_KEY=

# ==============================================================================
# SECГ‡ГѓO 9 вЂ” RUNTIME POLISH (SOTA 2026)
# ==============================================================================

# GOMEMLIMIT=      (limite memГіria Go em containers)
# GOGC=100         (GC: maior = menos CPU, mais RAM)
# GO_RUNTIME_POLISH_ENABLED=
