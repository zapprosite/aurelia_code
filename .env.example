# ==============================================================================
# AURÉLIA — SOBERANA 2026 (TEMPLATE DE SECRETS & VISIBILIDADE IA)
# ==============================================================================
# ESTE ARQUIVO É O ESPELHO ESTRUTURAL DO .env REAL.
# QUALQUER AGENTE IA PODE LER ESTE ARQUIVO PARA ENTENDER A INFRAESTRUTURA.
# OS VALORES REAIS RESIDEM APENAS NO .env (PROTEGIDO POR .gitignore).
# ==============================================================================

# --- CLOUDFLARE (DNS & INFRA) ---
# Token principal da Cloudflare Dashboard (ex: Edit Zone DNS)
CLOUDFLARE_API_TOKEN=
# ID da conta (extraído via cloudflared)
CLOUDFLARE_ACCOUNT_ID=
# ID da Zona zappro.site
CLOUDFLARE_ZONE_ID=
# Nome do domínio principal
CLOUDFLARE_ZONE_NAME=
# Email administrativo da conta
CLOUDFLARE_ACCOUNT_EMAIL=
# Token para integração MCP (Model Context Protocol)
CLOUDFLARE_MCP_TOKEN=

# --- CLOUDFLARE TUNNEL (SECURE ACCESS) ---
# Nome do túnel local configurado no homelab
CF_TUNNEL_NAME=
# UUID do túnel persistido em ~/.cloudflared/
CF_TUNNEL_ID=
# Segredo do túnel para autenticação do conector
CF_TUNNEL_SECRET=
# Hostname de entrada padrão
CF_TUNNEL_CNAME=

# --- TAILSCALE (MESH VPN) ---
# IP da rede privada Tailscale para acesso remoto
# TAILSCALE_IP deduplicated (see line 35)
TAILSCALE_IP=
# Nome do nó na rede Tailscale
TAILSCALE_HOSTNAME=

# --- TELEGRAM BOTS (IDENTIDADES) ---
# 1. Bot Mestre (Aurélia)
TELEGRAM_BOT_TOKEN=
# 2. Assistente de Vendas
TELEGRAM_BOT_TOKEN_AC_VENDAS=
# 3. Organizadora de Rotinas
TELEGRAM_BOT_TOKEN_ORGANIZADORA=
# 4. Gestor de Agenda
TELEGRAM_BOT_TOKEN_AGENDA=
# 5. Controlador de Banco de Dados
TELEGRAM_BOT_TOKEN_CONTROLE_DB=
# 6. Monitor de Caixa/Financeiro
TELEGRAM_BOT_TOKEN_CAIXA=
# 7. Bot de Notificações do Sistema
TELEGRAM_NOTIFICATION_BOT_ID=

# --- LLM APIs (TIER 0 & CLOUD) ---
# Chave OpenRouter para modelos de alta performance (Tier 1+)
OPENROUTER_API_KEY=
TAVILY_API_KEY=
# Chave Groq para Llama-3 inferência ultra-rápida (Tier 0 local/cloud bridge)
GROQ_API_KEY=
# --- GOOGLE ---
# Chave Gemini (Google Cloud)
GOOGLE_API_KEY=
# Token HuggingFace para download de pesos e modelos
HF_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LITELLM PROXY (ORQUESTRADOR) ---
# Senha mestra administrativa do Proxy
LITELLM_MASTER_KEY=
# Chave virtual para consumo de agentes
LITELLM_VIRTUAL_KEY=
# Localização do banco do LiteLLM (Porta 5440)
LITELLM_POSTGRES_HOST=
LITELLM_POSTGRES_PORT=
LITELLM_POSTGRES_USER=
LITELLM_POSTGRES_DB=
LITELLM_POSTGRES_PASSWORD=
# Endpoints públicos e locais
LITELLM_URL=
LITELLM_LOCAL_URL=
LITELLM_UI_URL=

# --- QDRANT (BANCO VETORIAL) ---
# API Key extraída de /srv/apps/platform/docker-compose.yml
QDRANT_API_KEY=
# Endpoints local e público
QDRANT_URL=
QDRANT_URL_PUBLIC=

# --- SUPABASE (CORE DB & AUTH) ---
# Senha mestra do PostgreSQL gerida pelo Docker
SUPABASE_POSTGRES_PASSWORD=
# Segredo JWT para assinar tokens
SUPABASE_JWT_SECRET=
# Chaves públicas/serviço enviadas ao frontend
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Senha de administração do dashboard
SUPABASE_DASHBOARD_PASSWORD=
SUPABASE_STUDIO_USER=
# URLs de acesso externas
SUPABASE_URL=
SUPABASE_STUDIO_URL=
# Portas locais
SUPABASE_DB_PORT=
SUPABASE_DB_DIRECT_PORT=

# --- N8N (WORKFLOW AUTOMATION) ---
# Senha do banco de dados n8n (extraída de docker-compose)
N8N_DB_PASSWORD=
# URL pública via tunnel
N8N_URL=

# --- CAPROVER (PaaS) ---
# Senha administrativa do CapRover
CAPROVER_PASSWORD=
# URL de gerenciamento
CAPROVER_URL=
# Senha de administração do Grafana (movida para CapRover)
GRAFANA_ADMIN_PASSWORD=

# --- GITHUB (REPO & CI/CD) ---
# Personal Access Token para gestão de issues e PRs
GITHUB_TOKEN=

# --- POSTGRES (SISTEMA) ---
# Senha global do postgres host (usada em scripts de backup)
POSTGRES_PASSWORD=

# --- AURELIA RUNTIME (CORE) ---
# URL do motor Ollama (Local LLM)
OLLAMA_URL=
# Diretório base de memória e logs
AURELIA_HOME=
# Endpoints de controle
AURELIA_HEALTH_URL=
AURELIA_DASHBOARD_URL=
AURELIA_MODE=

# --- EXTRA / CUSTOM SECRETS (Sovereign 2026 Extension) ---
TELEGRAM_TOKEN_CAIXA=
TELEGRAM_TOKEN_VENDAS=
TELEGRAM_TOKEN_OBRAS=
TELEGRAM_TOKEN_AGENDA=
TELEGRAM_TOKEN_INFRA=
TELEGRAM_TOKEN_DB=
N8N_API_KEY=
OBSIDIAN_VAULT_PATH=
