*.db
*.db.*
*.sqlite
*.sqlite.*
*.sqlite3
*.sqlite3.*
data/*.db
data/*.db.*
data/*.sqlite
data/*.sqlite3
data/*.db-journal
data/*.sqlite-journal
data/*.sqlite3-journal

